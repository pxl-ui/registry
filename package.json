{
  "name": "@pxl-ui/registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shadcn components registry for PXL-UI",
  "homepage": "https://pxl-ui.github.io/registry",
  "keywords": [
    "shadcn",
    "shadcn-ui",
    "shadcn-registry",
    "8bitcn"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "registry:serve": "pnpm run registry:build && http-serve public -p 3000",
    "registry:build": "shadcn build",
    "upgrade:shadcn": "npx --yes shadcn@canary add --all --overwrite --yes",
    "upgrade:packages": "pnpx npm-check-updates --interactive --format group"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.523.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "http-serve": "^1.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
